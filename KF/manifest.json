{
  "manifest_version": 3,
  "name": "Tab Switch Counter",
  "version": "1.0",

  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ]
}